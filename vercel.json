{
  "version": 2,
  "builds": [
    { "src": "api/naver-token.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/naver-token", "dest": "/api/naver-token.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
